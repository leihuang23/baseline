# Baseline local development environment.
# Copy to .env and keep real secrets out of source control.

APP_ENV=local
DATABASE_URL=postgresql+psycopg://baseline@localhost:5433/baseline
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
LLM_DEFAULT_PROVIDER=deepseek
LLM_CHEAP_MODEL=deepseek-v4-pro
LLM_STRONG_MODEL=deepseek-v4-pro
LLM_FALLBACK_MODEL=baseline-local-deterministic-v1
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
# DEEPSEEK_API_KEY=replace-with-local-secret
DAILY_BRIEFING_COST_BUDGET=1.0
MODEL_PROVIDER_FAILURE_ALERT_THRESHOLD=3
SCHEMA_VALIDATION_FAILURE_ALERT_THRESHOLD=3
DAILY_BRIEFING_FAILURE_ALERT_THRESHOLD=1
SYNC_FAILURE_ALERT_THRESHOLD=3
DELETION_FAILURE_ALERT_THRESHOLD=1
