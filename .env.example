# Baseline local development environment.
# Copy to .env and keep real secrets out of source control.

APP_ENV=local
DATABASE_URL=postgresql+psycopg://baseline@localhost:5433/baseline
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
# Required when APP_ENV=staging or APP_ENV=production. Set the same value in the iOS
# BASELINE_API_AUTH_TOKEN environment or BaselineAPIAuthToken Info.plist key.
# BASELINE_API_AUTH_TOKEN=replace-with-local-secret
LLM_DEFAULT_PROVIDER=deepseek
LLM_CHEAP_MODEL=deepseek-v4-pro
LLM_STRONG_MODEL=deepseek-v4-pro
LLM_FALLBACK_MODEL=baseline-local-deterministic-v1
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
# DEEPSEEK_API_KEY=replace-with-local-secret
DAILY_BRIEFING_COST_BUDGET=1.0
MODEL_PROVIDER_FAILURE_ALERT_THRESHOLD=3
SCHEMA_VALIDATION_FAILURE_ALERT_THRESHOLD=3
DAILY_BRIEFING_FAILURE_ALERT_THRESHOLD=1
SYNC_FAILURE_ALERT_THRESHOLD=3
DELETION_FAILURE_ALERT_THRESHOLD=1
# Local/test default is a temp-backed encrypted export store. Staging and
# production must set a durable private directory.
# EXPORT_STORAGE_DIR=/var/lib/baseline/exports
EXPORT_RETENTION_HOURS=24
EXPORT_CLEANUP_ON_START=true
# Offline/test retrieval uses deterministic hash embeddings. Set these for a
# production OpenAI-compatible embedding endpoint.
KNOWLEDGE_EMBEDDING_PROVIDER=hash
# KNOWLEDGE_EMBEDDING_API_URL=https://api.example.com/v1/embeddings
# KNOWLEDGE_EMBEDDING_API_KEY=replace-with-embedding-key
# KNOWLEDGE_EMBEDDING_MODEL=text-embedding-model
